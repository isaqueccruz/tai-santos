{
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install",
  "framework": "other",
  "outputDirectory": "dist",
  "devCommand": "pnpm dev",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "dist/index.js": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/trpc/:path*",
      "destination": "/dist/index.js"
    },
    {
      "source": "/api/oauth/:path*",
      "destination": "/dist/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/dist/index.js"
    }
  ]
}
